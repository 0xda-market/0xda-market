{$DOMAIN} {
  encode zstd gzip

  handle_path /bot/* {
    reverse_proxy market-bot:10000 {
      health_uri /health
      health_interval 30s
      health_timeout 5s
      lb_try_duration 5s
    }
  }

  handle {
    reverse_proxy api:10000 {
      health_uri /health
      health_interval 30s
      health_timeout 5s
      lb_try_duration 5s
    }
  }

  log {
    output stdout
    format json
  }
}

{$MIND_WEB_DOMAIN:mind.nilx.one} {
  encode zstd gzip

  reverse_proxy mind-web:80 {
    health_uri /health
    health_interval 30s
    health_timeout 5s
    lb_try_duration 5s
  }

  log {
    output stdout
    format json
  }
}
