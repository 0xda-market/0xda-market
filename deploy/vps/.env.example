DOMAIN=nilx.one
PORT=10000
RACK_ENV=production
PUMA_THREADS=5

DATABASE_URL=postgresql://postgres:password@host:5432/postgres
PUBLIC_API_TOKEN=replace-me
MANUAL_PROVIDER_TOKEN=replace-me
ADMIN_TELEGRAM_IDS=

# Legacy in-process Telegram transport only. Dedicated bot services should keep
# their own bot tokens outside this core service.
TELEGRAM_CLIENT_BOT_TOKEN=
TELEGRAM_BROKER_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=https://nilx.one

# Keep disabled until DNS points at the VPS and Caddy has issued a certificate.
VERIFY_PUBLIC_HTTPS=0
